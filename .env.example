# Runtime
ENVIRONMENT=development
APP_VERSION=0.1.0
# STARTUP_VALIDATION_STRICT=true for deployed backend services.
PUBLIC_API_BASE_URL=http://localhost:8000
FRONTEND_PUBLIC_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=

# Afferens. Replace locally in .env; never commit real keys.
AFFERENS_API_KEY=replace_with_afferens_api_key
AFFERENS_BASE_URL=https://afferens.com
AFFERENS_TIMEOUT_SECONDS=10

# Durable memory database.
DATABASE_ENABLED=true
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/afferens_memory_guardian
DATABASE_CONNECT_TIMEOUT_SECONDS=5

# Fireworks reasoning. Optional; deterministic evidence-backed fallback is used when absent.
FIREWORKS_API_KEY=replace_with_fireworks_api_key
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_MODEL=accounts/fireworks/models/deepseek-v4-flash

# Optional LangSmith tracing for LangGraph workflow debugging.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=replace_with_langsmith_api_key
LANGSMITH_PROJECT=afferens-memory-guardian-local
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_TRACE_CONTENT=false

# Deferred provider seams. These are surfaced in provider status but are not live runtime providers.
GEMINI_API_KEY=replace_with_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash
PARCLE_API_KEY=replace_with_parcle_api_key
PARCEL_API_KEY=replace_with_parcel_api_key

# Optional Afferens actuation. Keep disabled unless manually validating against a safe live node.
AFFERENS_ACTUATION_ENABLED=false
AFFERENS_ACTUATION_SUPPORTED_COMMANDS=TRIGGER_ALARM,CAPTURE_FRAME

# Action intelligence adapters.
ACTION_YOLO_FALL_ENABLED=true
ACTION_YOLO_FALL_MODEL_PATH=backend/models/project-memoria-fall-best.pt
ACTION_YOLO_FALL_CONFIDENCE_THRESHOLD=0.6
ACTION_YOLO_FALL_FALLEN_LABELS=fall,fallen,fallen_person,lying,lying_down,lying_on_floor,horizontal_posture,floor_posture
ACTION_YOLO_FALL_NON_FALLEN_LABELS=not_fallen,standing,person,upright,sitting
ACTION_FALL_PERSISTENCE_SECONDS=3.5
ACTION_FALL_DEBOUNCE_SECONDS=120
ACTION_DRINK_MIN_WINDOW_SECONDS=1.0
ACTION_RAW_VIDEO_STORAGE_ENABLED=false
ACTION_MAX_FRAME_BYTES=4000000

# Semantic memory. Lexical retrieval works; vector embeddings are enabled only when configured and verified.
SEMANTIC_MEMORY_ENABLED=false
EMBEDDING_PROVIDER=none
EMBEDDING_MODEL=replace_with_embedding_model

# Frontend. This value is public in the browser and must not contain secrets.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Same-origin MediaPipe assets are prepared by `cd frontend && npm run setup:mediapipe`.
NEXT_PUBLIC_MEDIAPIPE_WASM_BASE_URL=/mediapipe/wasm
NEXT_PUBLIC_MEDIAPIPE_POSE_MODEL_URL=/mediapipe/models/pose_landmarker_lite.task
NEXT_PUBLIC_MEDIAPIPE_HAND_MODEL_URL=/mediapipe/models/hand_landmarker.task

# Optional caregiver access boundary. This is not a full auth system.
# Keep provider/API keys server-side; never prefix secrets with NEXT_PUBLIC_.
CAREGIVER_ACCESS_ENABLED=false
CAREGIVER_PASSCODE=replace_with_caregiver_passcode

# Product runtime must stay live-only. Test fixtures belong in test commands.
FIXTURE_MODE=false
